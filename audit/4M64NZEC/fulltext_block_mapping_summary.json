    },
    {
      "block_id": "p2:5",
      "page": 2,
      "role": "body_paragraph",
      "zone": "",
      "render_default": true,
      "snippet": "选取浙江中医药大学附属第一医院2022年8月—2023年8月收治的处于冻结期的30例FS患者作为观察组，另选取同期30名健康成人作为对照组（未报告任何肩部疼痛，",
      "found_in_fulltext": true,
