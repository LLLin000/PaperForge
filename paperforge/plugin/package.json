{
  "name": "paperforge-plugin",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/sql.js": "^1.4.11",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
    "lint-staged": "^17.0.8",
    "obsidian": "^1.12.0",
    "obsidian-test-mocks": "^2.0.0",
    "prettier": "^3.8.4",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  }
}
