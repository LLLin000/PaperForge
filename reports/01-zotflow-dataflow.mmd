    Reader --> PDFJS
    Reader --> AM
    AM -->|"annotationsSaved"| RB
    AM -->|"annotationsDeleted"| RB
    WB <-->|"extractExternalAnnotations"| PDFW
    Plugin --> CM6
    Plugin --> Tree
    Plugin --> Activity
    Plugin -->|"LocalReader"| ZF

    style ZAPI fill:#f9f,stroke:#333,stroke-width:2px
